{
  "name": "ntr-application",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win",
    "electron:build:all": "vite build && electron-builder --win --linux --mac"
  },
  "build": {
    "appId": "com.iotblitz.outlet-management",
    "productName": "Outlet Management System",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "src/assets/logo/app_icon_256.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "src/assets/logo/app_icon_256.png",
      "uninstallerIcon": "src/assets/logo/app_icon_256.png",
      "installerHeaderIcon": "src/assets/logo/app_icon_256.png"
    }
  },
  "dependencies": {
    "@ant-design/charts": "^2.3.0",
    "@ant-design/icons": "^6.0.0",
    "@react-google-maps/api": "^2.20.6",
    "antd": "^5.25.1",
    "axios": "^1.9.0",
    "chart.js": "^4.4.9",
    "framer-motion": "^12.12.1",
    "google-map-react": "^2.2.5",
    "leaflet": "^1.9.4",
    "lottie-react": "^2.4.1",
    "lottie-web": "^5.12.2",
    "lucide-react": "^0.511.0",
    "moment": "^2.30.1",
    "react": "^19.1.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.6.0",
    "recharts": "^2.15.3",
    "styled-components": "^6.1.18",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
